[gd_resource type="Resource" script_class="OverworldMapData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/OverworldMapData.gd" id="1_map_data"]

[resource]
script = ExtResource("1_map_data")
map_name = "Pepemon Route 1"
player_start_cell = Vector2i(8, 8)
rows = Array[String](["################", "#..............#", "#..GGGG........#", "#..GGGG....G...#", "#..............#", "#...##########.#", "#...#S.......#.#", "#...#....GGGG#.#", "#...#..S.GGGG#.#", "#...#....GGGG#.#", "#...#....GGGS#.#", "#...##########.#", "#..............#"])
sign_messages = Array[Dictionary]([{ "cell": Vector2i(7, 8), "message": "Pepemon Route 1\nTall grass hides wild monsters." }, { "cell": Vector2i(5, 6), "message": "Route Tip\nUse Potions before trainer battles." }, { "cell": Vector2i(12, 10), "message": "Training Notice\nWater beats Fire, Fire beats Grass." }])

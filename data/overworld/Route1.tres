[gd_resource type="Resource" script_class="OverworldMapData" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/data/OverworldMapData.gd" id="1_map_data"]
[ext_resource type="Resource" path="res://data/monsters/WaterMonster.tres" id="2_water_monster"]

[resource]
script = ExtResource("1_map_data")
map_name = "Pepemon Route 1"
player_start_cell = Vector2i(8, 8)
rows = Array[String](["################", "#..............#", "#..GGGG........#", "#..GGGG....G...#", "#..............#", "#...##########.#", "#...#S.......#.#", "#...#....GGGG#.#", "#...#..S.GGGG#.#", "#...#....GGGG#.#", "#...#....GGGS#.#", "#...##########.#", "#..............#"])
sign_messages = Array[Dictionary]([{ "cell": Vector2i(7, 8), "message": "Pepemon Route 1\nTall grass hides wild monsters." }, { "cell": Vector2i(5, 6), "message": "Route Tip\nUse Potions before trainer battles." }, { "cell": Vector2i(12, 10), "message": "Training Notice\nWater beats Fire, Fire beats Grass." }])
interactables = Array[Dictionary]([{ "id": "scout_mira", "name": "ScoutMira", "cell": Vector2i(8, 7), "dialogue": "Scout Mira: Monsters get faster as they level up.", "action": 0, "blocks_movement": true }, { "id": "keeper_sol", "name": "KeeperSol", "cell": Vector2i(6, 10), "dialogue": "Keeper Sol: Every route has its own encounter table.", "action": 0, "blocks_movement": true }, { "id": "trainer_rook", "name": "TrainerRook", "cell": Vector2i(10, 6), "dialogue": "Rook: Let's test your team.", "defeated_dialogue": "Rook: Good match. Your timing is sharp.", "action": 1, "battle_monster": ExtResource("2_water_monster"), "battle_level": 4, "blocks_movement": true }, { "id": "trainer_vale", "name": "TrainerVale", "cell": Vector2i(11, 9), "dialogue": "Vale: My water partner is ready.", "defeated_dialogue": "Vale: Next time, I'll bring a faster partner.", "action": 1, "battle_monster": ExtResource("2_water_monster"), "battle_level": 5, "blocks_movement": true }])

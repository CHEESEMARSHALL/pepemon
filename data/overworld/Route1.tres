[gd_resource type="Resource" script_class="OverworldMapData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/data/OverworldMapData.gd" id="1_map_data"]
[ext_resource type="Resource" path="res://data/monsters/WaterMonster.tres" id="2_water_monster"]
[ext_resource type="Resource" path="res://data/encounters/StarterGrass.tres" id="3_starter_grass"]

[resource]
script = ExtResource("1_map_data")
map_name = "Pepemon Route 1"
player_start_cell = Vector2i(8, 8)
encounter_table = ExtResource("3_starter_grass")
rows = Array[String](["................", "................", "...GGGG.........", "...GGGG....G....", "................", "................", "................", ".........GGGG...", ".........GGGG...", ".........GGGG...", ".........GGGG...", "................", "................"])
overlay_rows = Array[String](["TTTTTTTTTTTTTTTT", "T.HHH.....TT...T", "T............T.T", "T..............T", "T..............T", "T...TTTTTTTTTT.T", "T...TS.......T.T", "T...T........T.T", "T...T..S.....T.T", "T...T........T.T", "T...T.......ST.T", "T...TTTTTTTTTT.T", "TTTTTTTTTTTTTTTT"])
sign_messages = Array[Dictionary]([{ "cell": Vector2i(7, 8), "message": "Pepemon Route 1\nTall grass hides wild monsters." }, { "cell": Vector2i(5, 6), "message": "Route Tip\nUse Potions before trainer battles." }, { "cell": Vector2i(12, 10), "message": "Training Notice\nWater beats Fire, Fire beats Grass." }])
inspect_messages = Array[Dictionary]([{ "cell": Vector2i(2, 1), "prompt": "Knock", "message": "The route keeper's cottage is quiet.\nSomeone has stacked fresh monster feed by the door." }])
interactables = Array[Dictionary]([{ "id": "scout_mira", "name": "ScoutMira", "cell": Vector2i(8, 7), "dialogue": "Scout Mira: Monsters get faster as they level up.", "action": 0, "blocks_movement": true }, { "id": "keeper_sol", "name": "KeeperSol", "cell": Vector2i(6, 10), "dialogue": "Keeper Sol: Every route has its own encounter table.", "action": 0, "blocks_movement": true }, { "id": "trainer_rook", "name": "TrainerRook", "cell": Vector2i(10, 6), "dialogue": "Rook: Let's test your team.", "defeated_dialogue": "Rook: Good match. Your timing is sharp.", "challenge_dialogue": "Rook: I saw you step into my training lane!", "sight_direction": Vector2i(0, 1), "sight_range": 3, "action": 1, "battle_monster": ExtResource("2_water_monster"), "battle_level": 4, "blocks_movement": true }, { "id": "trainer_vale", "name": "TrainerVale", "cell": Vector2i(11, 9), "dialogue": "Vale: My water partner is ready.", "defeated_dialogue": "Vale: Next time, I'll bring a faster partner.", "challenge_dialogue": "Vale: Hold it. Battle me before you pass.", "sight_direction": Vector2i(0, 1), "sight_range": 1, "action": 1, "battle_monster": ExtResource("2_water_monster"), "battle_level": 5, "blocks_movement": true }, { "id": "route1_potion", "name": "Route1Potion", "cell": Vector2i(5, 2), "dialogue": "Found a Potion.", "collected_dialogue": "The supply spot is empty.", "action": 2, "item_key": "potion", "item_name": "Potion", "item_count": 1, "blocks_movement": true }, { "id": "route1_capsules", "name": "Route1Capsules", "cell": Vector2i(12, 2), "dialogue": "Found 2 Capture Capsules.", "collected_dialogue": "The capsule case is empty.", "action": 2, "item_key": "capture_capsule", "item_name": "Capture Capsule", "item_count": 2, "blocks_movement": true }])
transitions = Array[Dictionary]([{ "cell": Vector2i(14, 6), "target_map_path": "res://data/overworld/Route2.tres", "target_start_cell": Vector2i(1, 6) }])
